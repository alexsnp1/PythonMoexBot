BOT_TOKEN=your_telegram_bot_token_here
DB_PATH=bot/spread-bot.sqlite
POLL_INTERVAL_SECONDS=10
ALERT_COOLDOWN_SECONDS=60
PRICE_PROVIDER=mock
TRADINGVIEW_TIMEFRAME=1
TRADINGVIEW_CANDLES=1
MOEX_CONTRACT_CONFIG_PATH=price/moex_contracts.json
# Optional: set your TradingView auth token to enable real-time data
TRADINGVIEW_AUTH_TOKEN=
# Optional: Unix timestamp or ISO 8601 when the token expires (for expiry warnings)
TRADINGVIEW_TOKEN_EXPIRES_AT=
# Optional: enable human-like randomized polling / pauses (reduces ban risk)
TRADINGVIEW_HUMAN_MODE=false
